{
  "name": "college-briand/candidature-echecs-briand",
  "description": "Gestion des candidatures pour la section sportive échecs",
  "type": "wordpress-plugin",
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "lint:php": "phpstan analyze"
  },
  "autoload-dev": {
        "psr-4": {
            "CEB\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "szepeviktor/phpstan-wordpress": true
        }
    }
}
